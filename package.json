{
  "expo": {
    "name": "ua-student-attendance",
    "slug": "ua-student-attendance",
    "owner": "iyawnnn",
    "scheme": "com.ua.studentattendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ua.studentattendance",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationForegroundPermission": "Allow UA Student Attendance to access your location to verify lab proximity."
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "57f4b565-4e9f-4bbe-8f3a-9d2eb47335c2"
      }
    }
  },
  "name": "ua-student-attendance",
  "version": "1.0.0",
  "scripts": {},
  "dependencies": {
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-picker/picker": "2.11.4",
    "expo": "~57.0.6",
    "expo-location": "~57.0.4",
    "expo-secure-store": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-quick-base64": "^3.0.1",
    "react-native-quick-crypto": "^1.1.6"
  },
  "devDependencies": {
    "@types/react": "~19.2.4",
    "typescript": "~6.0.3"
  }
}
